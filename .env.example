# Backend Environment Variables (example)
# Copy to `.env` and fill in your values.
#
# NOTE: Do not commit real secrets (service role keys, API keys, Stripe secret keys).

# Supabase Configuration (Backend)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI GPT-5.2 Configuration (Primary AI Provider)
# Required: set this directly in env (OpenAI key is not loaded from Supabase app_config)
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-5.2
# OpenAI cost estimation (optional)
OPENAI_COST_PER_1M_INPUT_TOKENS=2.5
OPENAI_COST_PER_1M_OUTPUT_TOKENS=10
OPENAI_COST_PER_SUMMARY_USD=0.1

# OpenAI cost guardrails (optional)
OPENAI_COST_PER_1K_TOKENS_USD=0.005
OPENAI_MAX_OUTPUT_TOKENS=9000
OPENAI_SUMMARY_TOKEN_RESERVE=0
OPENAI_REQUEST_TIMEOUT_SECONDS=120

# Summary pipeline timeout controls (optional)
SUMMARY_TOTAL_TIMEOUT_SECONDS=180
SUMMARY_AGENT1_TIMEOUT_SECONDS=25
SUMMARY_AGENT2_TIMEOUT_SECONDS=120
SUMMARY_REWRITE_TIMEOUT_SECONDS=120
# Summary budget adaptation knobs (optional)
SUMMARY_AGENT1_MAX_OUTPUT_TOKENS=700
SUMMARY_RESEARCH_MAX_WORDS=350
# Optional explicit token reserve for Agent-1 research in preflight prompt caps.
# Leave unset/blank to auto-derive from SUMMARY_RESEARCH_MAX_WORDS.
SUMMARY_RESEARCH_TOKEN_RESERVE=
# Optional non-core fallback clamps used before hard budget failure.
SUMMARY_SNIPPETS_REDUCED_MAX_CHARS=1200
SUMMARY_RISK_EXCERPT_REDUCED_MAX_CHARS=5000
# Long-form summary contract handling:
# 1 = fail with 422 when strict narrative+quote contract is not met
# 0 = return best-effort summary with `summary_meta.contract_missing_requirements`
SUMMARY_STRICT_LONGFORM_CONTRACT_REQUIRED=1

# Summary model routing (OpenAI-only)
OPENAI_SUMMARY_PRIMARY_MODEL_NAME=gpt-5.2
OPENAI_SUMMARY_FALLBACK_MODEL_NAME=gpt-5.2

# EODHD API Configuration (use "demo" for testing)
EODHD_API_KEY=demo

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Debug mode
DEBUG=false

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Choose one:
STRIPE_PRICE_ID=
STRIPE_PRICE_LOOKUP_KEY=pro_monthly

# Site URL used for Stripe redirects (recommended in production)
SITE_URL=http://localhost:3000

# PostHog analytics (optional, recommended)
# Backend/server-side capture (AI costs, summary events)
POSTHOG_ENABLED=true
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_TIMEOUT_SECONDS=0.8

# Frontend/browser analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_DEBUG=false
