# Backend Environment Variables (example)
# Copy to `.env` and fill in your values.
#
# NOTE: Do not commit real secrets (service role keys, API keys, Stripe secret keys).

# Supabase Configuration (Backend)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini AI Configuration
GEMINI_API_KEY=
# Gemini cost estimation (optional)
GEMINI_COST_PER_1M_INPUT_TOKENS=
GEMINI_COST_PER_1M_OUTPUT_TOKENS=
GEMINI_COST_PER_SUMMARY_USD=0.1

# EODHD API Configuration (use "demo" for testing)
EODHD_API_KEY=demo

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Debug mode
DEBUG=false

# Stripe Billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Choose one:
STRIPE_PRICE_ID=
STRIPE_PRICE_LOOKUP_KEY=pro_monthly

# Site URL used for Stripe redirects (recommended in production)
SITE_URL=http://localhost:3000
